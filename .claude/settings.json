{
  "permissions": {
    "allow": [
      "Write()",
      "Edit()",
      "Bash(*)",
      "Glob(*)",
      "Grep(*)",
      "LS(*)",
      "Read(*)",
      "MultiEdit(*)",
      "NotebookRead(*)",
      "NotebookEdit(*)",
      "WebFetch(*)",
      "TodoRead()",
      "TodoWrite(*)",
      "WebSearch(*)",
      "Task(*)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(rmdir:*)",
      "Bash(del:*)",
      "Bash(unlink:*)"
    ]
  }
}