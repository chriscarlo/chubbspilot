# SConstruct for generating Python bindings for offline.capnp
import os
import subprocess
from SCons.Script import Environment, Dir, File, Glob
import SCons.Errors # Import SCons Errors

# Setup environment (could potentially inherit from parent)
# env = Environment() # Commented out - should use Imported 'env'

# --- REMOVED ALL OFFLINE.CAPNP COMPILATION RULES ---
# offline_schema = File('offline.capnp')
# target_dir = Dir('.')
# cpp_targets = [...]
# cpp_command = ...
# cython_plugin_path = ...
# capnp_include_path = ...
# cython_targets = [...]
# cython_command = ...
# env.Depends(cython_command, cpp_targets)
# target_so_name = ...
# target_so = ...
# build_deps = ...
# build_command_str = ...
# build_command = ...
# env.Depends(build_command, ...)
# cleanup_targets = ...
# env.Clean(...)
# Alias(...)

# --- START ADDITION: FrogPilot Protobuf Compilation ---
Import('env') # Import the main environment from parent SConstruct

# Define paths relative to the SConstruct root (#) or this SConscript file
proto_out_dir_rel = '.' # Output relative to this SConscript
proto_out_dir_abs = '#selfdrive/frogpilot/navigation/mapd_py' # Absolute path from repo root
proto_src_dir_abs = '#tools/map_processing' # Absolute path from repo root

# Define source and target files using absolute paths for clarity
proto_src = proto_src_dir_abs + '/osm_speed_data.proto'
proto_target_name = 'osm_speed_data_pb2.py'
proto_target = os.path.join(proto_out_dir_rel, proto_target_name)
protoc_binary = '#tools/bin/protoc' # Use the checked-in binary
init_file_target = os.path.join(proto_out_dir_rel, '__init__.py')

# Ensure the __init__.py exists (needed for relative imports)
# Using env.Command ensures it's part of the build graph
env.Command(init_file_target, None, f'touch $TARGET') # Simple touch should be fine here

# Define the rule to compile the FrogPilot protobuf schema
# Note: Using absolute paths for clarity in the command string parts
protoc_command_str = f'{protoc_binary} --proto_path={proto_src_dir_abs} --python_out={proto_out_dir_abs} {proto_src}'

# --- START Python Action Function ---
def run_protoc(target, source, env):
    # target, source, env are standard arguments for SCons actions
    # We use the command string defined above
    print(f"--- Running SCons Python Action for {str(target[0])} ---")
    # Substitute SCons variables like #
    cmd_str_subst = env.subst(protoc_command_str)
    print(f"Command: {cmd_str_subst}")
    # Split command for subprocess.run (basic split should work if no quoted args)
    cmd_parts = cmd_str_subst.split()
    print(f"Executing: {cmd_parts}")
    try:
        # Execute command, capture output
        # Use cwd='.' explicitly if needed, though absolute paths should work
        result = subprocess.run(cmd_parts, check=True, capture_output=True, text=True, cwd=Dir('#').abspath)
        print("STDOUT:\\n" + result.stdout)
        print("STDERR:\\n" + result.stderr)
        print("--- SCons Action Completed Successfully ---")
        # Must touch the target file explicitly since SCons doesn't know the action created it
        # open(str(target[0]), 'a').close() # This causes issues if action fails but file exists
        # SCons should handle timestamp update if command succeeds
    except subprocess.CalledProcessError as e:
        print(f"!!! SCons Action FAILED !!!")
        print(f"Return Code: {e.returncode}")
        print("STDOUT:\\n" + e.stdout)
        print("STDERR:\\n" + e.stderr)
        # Raise an exception to signal failure to SCons
        # Use errstr for the message
        raise SCons.Errors.BuildError(node=target[0], errstr=f"protoc failed with stderr:\\n{e.stderr}")
    except FileNotFoundError as e:
        print(f"!!! SCons Action FAILED (FileNotFound) !!!")
        print(f"Failed command: {cmd_parts}")
        print(str(e))
        raise SCons.Errors.BuildError(node=target[0], errstr=f"protoc command not found or path issue: {str(e)}")
    except Exception as e:
        print(f"!!! SCons Action FAILED (Unknown Error) !!!")
        print(str(e))
        raise SCons.Errors.BuildError(node=target[0], errstr=f"protoc failed: {str(e)}")
# --- END Python Action Function ---

# Create the build command, depending on the source, binary, and init file
# Use the Python function 'run_protoc' as the action instead of the command string
print(">>> DEFINING mapd_py SConscript Rule using Python Action <<<")
protobuf_py_file = env.Command(proto_target, [proto_src, init_file_target, protoc_binary], run_protoc) # Pass function handle

# Optional: Alias if this generated file needs to be referred to elsewhere
# Alias('frogpilot_proto', protobuf_py_file)

# --- START ADDITION: Add to default build ---
# Ensure this generated file is considered part of the default build
Alias('default', protobuf_py_file)
# --- END ADDITION ---

# Return nothing specific; the env.Command defines the build rule.
Return([])