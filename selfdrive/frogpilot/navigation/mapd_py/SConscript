# SConstruct for generating Python bindings for offline.capnp
import os
from SCons.Script import Environment, Dir, File, Glob

# Setup environment (could potentially inherit from parent)
env = Environment()

# --- REMOVED ALL OFFLINE.CAPNP COMPILATION RULES ---
# offline_schema = File('offline.capnp')
# target_dir = Dir('.')
# cpp_targets = [...]
# cpp_command = ...
# cython_plugin_path = ...
# capnp_include_path = ...
# cython_targets = [...]
# cython_command = ...
# env.Depends(cython_command, cpp_targets)
# target_so_name = ...
# target_so = ...
# build_deps = ...
# build_command_str = ...
# build_command = ...
# env.Depends(build_command, ...)
# cleanup_targets = ...
# env.Clean(...)
# Alias(...)

# --- START ADDITION: FrogPilot Protobuf Compilation ---
Import('env') # Import the main environment from parent SConstruct

# Define paths relative to the SConstruct root (#) or this SConscript file
proto_out_dir_rel = '.' # Output relative to this SConscript
proto_out_dir_abs = '#selfdrive/frogpilot/navigation/mapd_py' # Absolute path from repo root
proto_src_dir_abs = '#tools/map_processing' # Absolute path from repo root

# Define source and target files using absolute paths for clarity
proto_src = proto_src_dir_abs + '/osm_speed_data.proto'
proto_target_name = 'osm_speed_data_pb2.py'
proto_target = os.path.join(proto_out_dir_rel, proto_target_name)
protoc_binary = '#tools/bin/protoc' # Use the checked-in binary
init_file_target = os.path.join(proto_out_dir_rel, '__init__.py')

# Ensure the __init__.py exists (needed for relative imports)
# Using env.Command ensures it's part of the build graph
env.Command(init_file_target, None, f'touch $TARGET') # Simple touch should be fine here

# Define the rule to compile the FrogPilot protobuf schema
# Note: Using absolute paths for clarity in the command string parts
protoc_command = f'{protoc_binary} --proto_path={proto_src_dir_abs} --python_out={proto_out_dir_rel} {proto_src}'

# Create the build command, depending on the source, binary, and init file
# SCons should handle path conversions (# -> absolute path)
protobuf_py_file = env.Command(proto_target, [proto_src, init_file_target, protoc_binary], protoc_command)

# Optional: Alias if this generated file needs to be referred to elsewhere
# Alias('frogpilot_proto', protobuf_py_file)

# --- START ADDITION: Add to default build ---
# Ensure this generated file is considered part of the default build
Alias('default', protobuf_py_file)
# --- END ADDITION ---

# Return nothing specific; the env.Command defines the build rule.
Return([])